<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Theme Style"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <Spinner
            android:id="@+id/spinnerstyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/Styles"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Font Style"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <Spinner
            android:id="@+id/spinnerfont"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/Fonts"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/textGifStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom GIF: None"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <Button
                android:id="@+id/buttonPickGif"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Select GIF"
                android:focusable="true"
                android:layout_marginEnd="8dp" />
            <Button
                android:id="@+id/buttonClearGif"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:text="Clear GIF" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Notifications on Screen"
            android:textStyle="bold"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">
            <Button
                android:id="@+id/buttonReset"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Reset"
                android:focusable="true"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_marginEnd="8dp" />
            <Button
                android:id="@+id/buttonsave"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:text="Save" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>