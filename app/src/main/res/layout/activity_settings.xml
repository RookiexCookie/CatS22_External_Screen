<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Typography Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?android:colorBackgroundFloating"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Typography"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font Style"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerfont"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/Fonts"
                    android:focusable="true"
                    android:nextFocusDown="@+id/sliderFontScale"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font Size Multiplier"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderFontScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.5"
                    android:valueTo="2.0"
                    android:stepSize="0.1"
                    android:value="1.0"
                    android:focusable="true"
                    android:nextFocusUp="@+id/spinnerfont"
                    android:nextFocusDown="@+id/buttonPickGif" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Background Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?android:colorBackgroundFloating"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Background"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/textGifStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custom Media: None"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/buttonPickGif"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Select"
                        android:focusable="true"
                        android:nextFocusUp="@+id/sliderFontScale"
                        android:nextFocusRight="@+id/buttonClearGif"
                        android:nextFocusDown="@+id/switchNotifications"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/buttonClearGif"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:focusable="true"
                        android:nextFocusUp="@+id/sliderFontScale"
                        android:nextFocusLeft="@+id/buttonPickGif"
                        android:nextFocusDown="@+id/switchNotifications"
                        android:text="Clear" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?android:colorBackgroundFloating"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Switch
                    android:id="@+id/switchNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Show Notifications"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:focusable="true"
                    android:nextFocusUp="@+id/buttonPickGif"
                    android:nextFocusDown="@+id/buttonReset" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonReset"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:focusable="true"
                android:nextFocusUp="@+id/switchNotifications"
                android:nextFocusRight="@+id/buttonsave"
                android:text="Reset" />

            <Button
                android:id="@+id/buttonsave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:nextFocusUp="@+id/switchNotifications"
                android:nextFocusLeft="@+id/buttonReset"
                android:text="Save" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>